{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"linter": {
		"rules": {
			"style": {
				"noRestrictedImports": {
					"level": "error",
					"options": {
						"paths": {
							"next/link": "Use InternalLink from @/components/internal-link in apps/chat."
						}
					}
				}
			}
		}
	},
	"overrides": [
		{
			"includes": ["components/internal-link.tsx"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": "off"
					}
				}
			}
		}
	]
}
