# [required] Generate: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=


# [required] Postgres URL — https://vercel.com/docs/storage/vercel-postgres/quickstart
DATABASE_URL=

# --- AI Gateway (pick one based on config.gateway) ---
# Vercel AI Gateway (default) — https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=
# OpenRouter (set gateway: "openrouter" in chat.config.ts) — https://openrouter.ai/keys
OPENROUTER_API_KEY=
# LiteLLM Proxy (set gateway: "litellm" in chat.config.ts) — https://docs.litellm.ai/
LITELLM_BASE_URL=
# Optional; only if your LiteLLM proxy requires auth
LITELLM_API_KEY=

# <chatjs-storage-provider>
# Vercel Blob — Vercel Blob. Prefers Vercel OIDC (VERCEL_OIDC_TOKEN + BLOB_STORE_ID, auto-rotating) and falls back to BLOB_READ_WRITE_TOKEN; pass token, oidcToken, or storeId manually for local dev or other hosts.
# Credential option: Read-write token
# Vercel Blob read/write token
BLOB_READ_WRITE_TOKEN=
# Credential option: Vercel OIDC (auto-rotating)
# Vercel OIDC token (auto-injected on Vercel)
VERCEL_OIDC_TOKEN=
# Blob store ID
BLOB_STORE_ID=
# Note: An explicit `token` wins over OIDC. Locally, set BLOB_READ_WRITE_TOKEN.
# </chatjs-storage-provider>

# [required for non-Vercel] Your app's public URL (e.g., https://myapp.com)
# On Vercel, this is auto-detected from VERCEL_URL
APP_URL="http://localhost:3000"

# --- Auth (pick ≥1) ---
# Google — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub — https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Vercel - https://vercel.com/docs/sign-in-with-vercel
VERCEL_APP_CLIENT_ID=
VERCEL_APP_CLIENT_SECRET=


# --- Observability (Langfuse) ---
# Create project → Settings → API keys — https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Optional
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# [optional] Generate: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
CRON_SECRET=

# --- Features ---
# [optional] Redis — https://vercel.com/docs/redis
REDIS_URL=
# [optional] OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# [optional] Tavily — https://app.tavily.com/
TAVILY_API_KEY=
# [optional] Exa — https://dashboard.exa.ai/
EXA_API_KEY=
# [optional] Firecrawl — https://www.firecrawl.dev/
FIRECRAWL_API_KEY=
# [optional] MCP connectors - Generate: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
MCP_ENCRYPTION_KEY=
