{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["dom", "dom.iterable", "esnext"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"skipLibCheck": true,
		"jsx": "react-jsx",
		"noEmit": true,
		"esModuleInterop": true,
		"isolatedModules": true
	},
	"include": ["src/**/*.ts", "test/**/*.ts"]
}
