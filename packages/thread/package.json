{
	"name": "@chatjs/thread",
	"version": "0.0.0",
	"description": "Headless threaded chat runtime for AI SDK UI messages",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/franciscomoretti/chat-js.git",
		"directory": "packages/thread"
	},
	"homepage": "https://github.com/franciscomoretti/chat-js/tree/main/packages/thread",
	"bugs": {
		"url": "https://github.com/franciscomoretti/chat-js/issues"
	},
	"keywords": [
		"chatjs",
		"ai",
		"ai-sdk",
		"thread",
		"chat"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./react": {
			"types": "./src/react.ts",
			"default": "./src/react.ts"
		}
	},
	"types": "./src/index.ts",
	"files": [
		"dist",
		"src",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"format": "bunx @biomejs/biome@2.4.10 check --write src test spike *.md package.json tsconfig.json tsconfig.build.json biome.jsonc",
		"spike:ai-sdk": "bun test spike/ai-sdk-integration.test.ts",
		"spike:external-chat": "bun test spike/use-chat-external-chat.test.tsx",
		"test:types": "tsc --noEmit"
	},
	"peerDependencies": {
		"@ai-sdk/react": "^3.0.0",
		"ai": "^6.0.0",
		"react": ">=18"
	},
	"devDependencies": {
		"@ai-sdk/react": "^3.0.152",
		"@types/bun": "^1.3.12",
		"@types/react": "19.2.7",
		"@types/react-test-renderer": "19.1.0",
		"ai": "^6.0.150",
		"react": "19.2.3",
		"react-test-renderer": "19.2.3",
		"typescript": "6.0.2"
	}
}
